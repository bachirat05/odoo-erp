<odoo>
  <record id="view_infra_request_form" model="ir.ui.view">
    <field name="name">infra.request.form</field>
    <field name="model">infra.request</field>
    <field name="arch" type="xml">
      <form>
        <header>
            <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="type"/>
            <field name="user_id"/>
            <field name="server_id"/>
            <field name="vm_id"/>
          </group>
          <notebook>
            <page string="Description">
              <field name="description"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_infra_request_list" model="ir.ui.view">
    <field name="name">infra.request.list</field>
    <field name="model">infra.request</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="type"/>
        <field name="user_id"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="action_infra_request" model="ir.actions.act_window">
    <field name="name">Demandes Utilisateurs Web</field>
    <field name="res_model">infra.request</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>