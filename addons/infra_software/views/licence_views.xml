<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_infra_licence_list" model="ir.ui.view">
        <field name="name">infra.licence.list</field>
        <field name="model">infra.licence</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_expiring_soon == True">
                <field name="name"/>
                <field name="server_id"/>
                <field name="expiration_date"/>
                <field name="is_expiring_soon" invisible="1"/> </list>
        </field>
    </record>

    <record id="view_infra_licence_form" model="ir.ui.view">
        <field name="name">infra.licence.form</field>
        <field name="model">infra.licence</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom du logiciel (ex: Windows Server)"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="license_key"/>
                            <field name="cost"/>
                        </group>
                        <group>
                            <field name="server_id"/>
                            <field name="expiration_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_infra_licence" model="ir.actions.act_window">
        <field name="name">Licences Logicielles</field>
        <field name="res_model">infra.licence</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_infra_root" 
              name="Infra Software &amp; Licences" 
              sequence="20"/>
    
    <menuitem id="menu_infra_licence" 
              name="Licences" 
              parent="menu_infra_root" 
              action="action_infra_licence"
              sequence="1"/>
</odoo>