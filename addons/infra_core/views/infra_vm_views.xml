<odoo>
  <!-- Vue Formulaire -->
  <record id="view_infra_vm_form" model="ir.ui.view">
    <field name="name">infra.vm.form</field>
    <field name="model">infra.vm</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="state"/>
            <field name="os"/>
            <field name="ram"/>
            <field name="cpu"/>
            <field name="storage"/>
            <field name="server_id"/>
            <field name="cluster_id"/>
          </group>
          <notebook>
            <page string="Adresses IP">
              <field name="ip_ids"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Vue Liste -->
  <record id="view_infra_vm_list" model="ir.ui.view">
    <field name="name">infra.vm.list</field>
    <field name="model">infra.vm</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="os"/>
        <field name="ram"/>
        <field name="cpu"/>
        <field name="state"/>
        <field name="server_id"/>
        <field name="cluster_id"/>
      </list>
    </field>
  </record>

  <!-- Action -->
  <record id="action_infra_vm" model="ir.actions.act_window">
    <field name="name">Machines Virtuelles</field>
    <field name="res_model">infra.vm</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>