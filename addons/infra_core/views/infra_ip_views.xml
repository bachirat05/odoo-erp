<odoo>
  <!-- Vue Formulaire -->
  <record id="view_infra_ip_form" model="ir.ui.view">
    <field name="name">infra.ip.form</field>
    <field name="model">infra.ip</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="type"/>
            <field name="vm_id"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Vue Liste -->
  <record id="view_infra_ip_list" model="ir.ui.view">
    <field name="name">infra.ip.list</field>
    <field name="model">infra.ip</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="type"/>
        <field name="vm_id"/>
      </list>
    </field>
  </record>

  <!-- Action -->
  <record id="action_infra_ip" model="ir.actions.act_window">
    <field name="name">Adresses IP</field>
    <field name="res_model">infra.ip</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>