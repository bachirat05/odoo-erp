<odoo>
  <!-- Vue Formulaire -->
  <record id="view_infra_cluster_form" model="ir.ui.view">
    <field name="name">infra.cluster.form</field>
    <field name="model">infra.cluster</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
          </group>
          <notebook>
            <page string="Machines Virtuelles">
              <field name="vm_ids"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Vue Liste -->
  <record id="view_infra_cluster_list" model="ir.ui.view">
    <field name="name">infra.cluster.list</field>
    <field name="model">infra.cluster</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
      </list>
    </field>
  </record>

  <!-- Action -->
  <record id="action_infra_cluster" model="ir.actions.act_window">
    <field name="name">Clusters</field>
    <field name="res_model">infra.cluster</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>